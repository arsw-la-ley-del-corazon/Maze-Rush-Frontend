# ==============================================
# Maze Rush Frontend - Environment Variables
# ==============================================
# Copia este archivo como .env y configura los valores apropiados

# API Configuration
# URL base del backend API (sin barra final)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Timeout para las peticiones HTTP en milisegundos
VITE_API_TIMEOUT=10000

# Authentication Configuration
# Clave para almacenar el estado de autenticación en localStorage
VITE_AUTH_STORAGE_KEY=auth_state

# Margen en segundos antes de la expiración del token para renovarlo automáticamente
VITE_AUTH_TOKEN_REFRESH_MARGIN=30

# Environment
# Entorno de ejecución (development, production, test)
VITE_NODE_ENV=development

# Application Configuration
# Nombre de la aplicación
VITE_APP_NAME=Maze Rush

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Socket Configuration (para uso futuro)
# URL del servidor de WebSockets
VITE_SOCKET_URL=http://localhost:8080

# Development/Debug Configuration
# Habilitar modo debug (true/false)
VITE_DEBUG=true

# Nivel de logging (error, warn, info, debug)
VITE_LOG_LEVEL=info

# ==============================================
# Valores de Producción Sugeridos:
# ==============================================
# VITE_API_BASE_URL=https://api.mazerush.com/api/v1
# VITE_SOCKET_URL=https://api.mazerush.com
# VITE_NODE_ENV=production
# VITE_DEBUG=false
# VITE_LOG_LEVEL=error